    "A assinatura será automaticamente renovada por %@/mês até ser cancelada.": {
      "comment": "A footer text that informs the user about the automatic renewal of their subscription and the price of the current plan. The argument is the monthly price of the current plan.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The subscription will automatically renew at %@/month until it is cancelled."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "The subscription will automatically renew at %@/month until it is cancelled."

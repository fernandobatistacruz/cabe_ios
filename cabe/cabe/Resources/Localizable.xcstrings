    "Tem certeza que deseja remover sua conta? Essa ação não pode ser desfeita." : {
      "comment" : "An alert message displayed when the user confirms they want to delete their account.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de-DE" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sind Sie sicher, dass Sie Ihr Konto entfernen möchten? Diese Aktion kann nicht rückgängig gemacht werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Are you sure you want to remove your account? This action cannot be undone."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Are you sure you want to remove your account? This action cannot be undone."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Estás seguro de que deseas eliminar tu cuenta? Esta acción no se puede deshacer."
          }
        },
        "es-ES" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Estás seguro de que deseas eliminar tu cuenta? Esta acción no se puede deshacer."
          }
        },
        "fr-FR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Êtes-vous sûr de vouloir supprimer votre compte ? Cette action ne peut pas être annulée."
          }
        },
        "it-IT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sei sicuro di voler rimuovere il tuo account? Questa azione non può essere annullata."
          }
        },
        "pt-BR" : {
